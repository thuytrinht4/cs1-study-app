# Save as  .streamlit/secrets.toml  and fill in your values.
# Add .streamlit/secrets.toml to .gitignore (already done). Never commit it.

SUPABASE_URL      = "https://YOUR-PROJECT.supabase.co"
SUPABASE_ANON_KEY = "eyJhbGciOi...your-anon-public-key..."

# Optional until Milestone M2 (AI marking). Leave blank to run M0/M1 free.
ANTHROPIC_API_KEY = ""

MODEL_MARKER  = "claude-haiku-4-5-20251001"
MODEL_ANALYST = "claude-sonnet-4-6"

# Optional single-user auto-login: set both to your account's email + password
# and the app signs in automatically (no login form, survives redeploys).
# Leave blank to use the normal login form.
APP_EMAIL    = ""
APP_PASSWORD = ""
